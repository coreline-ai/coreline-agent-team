{
  "name": "agent-team",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "description": "Headless multi-agent team runtime scaffold extracted from claude-code",
  "bin": {
    "agent-team": "./dist/src/team-cli/bin.js",
    "atcli": "./dist/src/atcli/bin.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/src/team-cli/bin.js",
    "soak:codex": "npm run build && node scripts/run-codex-repeated-soak.mjs",
    "soak:codex:check": "npm run build && node scripts/check-codex-repeated-soak.mjs",
    "test": "npm run build && node --test dist/tests/team-core/*.test.js dist/tests/team-runtime/*.test.js dist/tests/team-cli/*.test.js dist/tests/team-operator/*.test.js dist/tests/team-tui/*.test.js"
  },
  "dependencies": {
    "ink": "^5.2.1",
    "ink-select-input": "^6.2.0",
    "ink-text-input": "^6.0.0",
    "proper-lockfile": "^4.1.2",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^18.3.12",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.9.3"
  }
}
